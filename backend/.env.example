# ---- HTTP ----
PORT=4000
CORS_ORIGIN=http://localhost:5173

# ---- PostgreSQL ----
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=pzem_db
# Set to "true" if your PG host enforces TLS (managed DBs usually do).
PGSSL=false

# ---- HiveMQ Cloud (MQTT over TLS) ----
MQTT_HOST=
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=pzem/device01/telemetry

# ---- OpenRouter AI Insights (OPTIONAL) -----------------------------------
# Leave OPENROUTER_API_KEY blank to fully disable the AI feature — the rest of
# the app runs fine without it.
#
# Get a free key at https://openrouter.ai/keys (no billing required for free
# models). Recommended free models:
#   - meta-llama/llama-3.3-70b-instruct:free     (default, good reasoning)
#   - deepseek/deepseek-chat-v3.1:free           (strong at structured output)
#   - google/gemini-2.0-flash-exp:free           (fast, shorter context)
#   - qwen/qwen-2.5-72b-instruct:free            (strong multilingual)
#
# Free-tier rate limits vary by model but are roughly 20 req/min and
# 50-200 req/day. The default 15-min interval gives ~96 requests/day,
# comfortably within limits for Llama 3.3 70B.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
INSIGHT_INTERVAL_MINUTES=15
INSIGHT_DEVICE=esp32_pzem_01

# OpenRouter uses these headers for attribution analytics on free-tier calls.
INSIGHT_APP_URL=http://localhost:4000
INSIGHT_APP_TITLE=PZEM Telemetry Console
