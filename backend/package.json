{
    "name": "pzem-telemetry-backend",
    "version": "1.0.0",
    "description": "MQTT → PostgreSQL → Socket.io pipeline for PZEM-004T energy telemetry.",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "seed": "node seed.js",
        "seed:clear": "node seed.js --clear",
        "db:init": "psql $DATABASE_URL -f schema.sql"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "mqtt": "^5.10.1",
        "pg": "^8.12.0",
        "socket.io": "^4.7.5"
    },
    "engines": {
        "node": ">=18"
    }
}